#include<bits/stdc++.h>
using namespace std;
int main()
{
	int p1, p2, p3, val, b, e;
	cin >> p1 >> p2 >> p3;
	string str, temp;
	cin >> str;
	for (size_t i = 0; i < str.length() - 1; i++) {
		if(str[i] == '-') {
			temp = "";
			b = str[i-1];
			e = str[i+1];
			if((48 <= b && b <= 57) && (48 <= e && e <= 57)) {
				for (int val = b+1; val < e; val++) {
					switch (p1) {
						case 2:
							for (int j = 0; j < p2; j++) {
								temp += (char)val;
								}
							break;
						case 3:
							for (int j = 0; j < p2; j++) {
								temp += (char)42;
							}
							break;
					}
				}
				
				str.replace(i, 1, temp);
			}
			if((97 <= b && b <= 122) && (97 <= e && e <= 122)) {
				switch (p2) {
					case 1:
						for (int val = b+1; val < e; val++) {
							for (int j = 0; j < p2; j++) {
								temp += (char)(val-32);
							}
						}

						break;
					case 2:
						for (int val = b+1; val < e; val++) {
							for (int j = 0; j < p2; j++) {
								temp += (char)val;
							}
						}
						break;
					case 3:
						break;

				}
				str.replace(i, 1, temp);
			}
		}
	}
	if (p3==2)
		std::reverse(str.begin(), str.end());
	cout << str;
	return 0;
}
